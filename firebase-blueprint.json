{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with authentication and role assignment",
      "type": "object",
      "properties": {
        "email": {
          "type": "string"
        },
        "role": {
          "type": "string",
          "enum": ["Admin", "Manager", "Agent"]
        },
        "name": {
          "type": "string"
        }
      },
      "required": ["email", "role"]
    },
    "Business": {
      "title": "Business",
      "description": "Business profile representing a workspace",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "category": {
          "type": "string"
        },
        "welcomeMessage": {
          "type": "string"
        },
        "whatsappPhoneNumber": {
          "type": "string"
        },
        "whatsappApiKey": {
          "type": "string"
        },
        "websiteUrl": {
          "type": "string"
        },
        "knowledgeBaseText": {
          "type": "string"
        },
        "ownerEmail": {
          "type": "string"
        },
        "revenue": {
          "type": "number"
        },
        "revenueGrowth": {
          "type": "number"
        },
        "leadsCount": {
          "type": "number"
        }
      },
      "required": ["id", "name"]
    },
    "Lead": {
      "title": "Lead",
      "description": "Omnichannel lead generated for a business",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "businessId": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "email": {
          "type": "string"
        },
        "phone": {
          "type": "string"
        },
        "source": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "value": {
          "type": "number"
        },
        "message": {
          "type": "string"
        },
        "encryptedDetails": {
          "type": "string"
        },
        "aiSummary": {
          "type": "string"
        },
        "aiSuggestedAction": {
          "type": "string"
        },
        "date": {
          "type": "string"
        }
      },
      "required": ["id", "businessId", "name"]
    },
    "SecurityLog": {
      "title": "SecurityLog",
      "description": "Audit trail log",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "timestamp": {
          "type": "string"
        },
        "user": {
          "type": "string"
        },
        "role": {
          "type": "string"
        },
        "action": {
          "type": "string"
        },
        "severity": {
          "type": "string"
        }
      },
      "required": ["id", "timestamp", "user", "action"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User records mapping uid to user info"
    },
    "/businesses/{businessId}": {
      "schema": "Business",
      "description": "Businesses and configurations"
    },
    "/leads/{leadId}": {
      "schema": "Lead",
      "description": "Leads collected per business"
    },
    "/logs/{logId}": {
      "schema": "SecurityLog",
      "description": "Security audit log"
    }
  }
}
